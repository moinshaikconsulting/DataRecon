# Port of the application server
PORT=3000

# Server execution environment state
NODE_ENV=production

# Database Configuration Options
# Connection string (Best for Render/Railway/Neon/Supabase)
DATABASE_URL=postgresql://recon_user:secure_password@localhost:5432/reconciliation_db

# Or individual authentication params (fallback)
PGHOST=localhost
PGPORT=5432
PGUSER=recon_user
PGPASSWORD=secure_password
PGDATABASE=reconciliation_db

# Gemini API Key for potential background audit AI insights 
GEMINI_API_KEY=
